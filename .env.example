# ============================================
# API KEYS - TEMPLATE (NÃO USE CHAVES REAIS!)
# ============================================

# TMDB API (https://www.themoviedb.org/)
# Obtenha sua chave em: https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Football API (https://www.api-football.com/)
# Obtenha sua chave em: https://dashboard.api-football.com/
FOOTBALL_API_KEY=

# Porta do servidor (Render usa automaticamente)
PORT=3000

# ============================================
# INSTRUÇÕES IMPORTANTES
# ============================================
# 1. Copie este arquivo para .env:
#    cp .env.example .env
#
# 2. Preencha as chaves no arquivo .env (NÃO neste!)
#
# 3. NUNCA commite o arquivo .env no Git
#
# 4. Este arquivo (.env.example) deve permanecer SEM chaves reais
#
# 5. Adicione .env ao .gitignore
